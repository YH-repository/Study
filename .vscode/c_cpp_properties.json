        "${workspaceFolder}/FWLIB/src",
        "${workspaceFolder}/SYSTEM",
        "${workspaceFolder}/CODE/CMSIS/CM3/CoreSupport",
        "${workspaceFolder}/CODE/CMSIS/CM3/DeviceSupport/ST/STM32F10x",
        "${workspaceFolder}/CODE",
        "${workspaceFolder}/FreeRTOS",
        "${workspaceFolder}/FreeRTOS/include",
        "${workspaceFolder}/FreeRTOS/portable"

      ],
      "defines": [
        "USE_STDPERIPH_DRIVER",
